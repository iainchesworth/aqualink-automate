<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="styles/pool-monitor.css" rel="stylesheet">
    
    <title>Aqualink Automate - Equipment Statistics</title>
</head>
<body>
    <!-- Top Navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-gradient-primary sticky-top shadow">
        <div class="container-fluid">
            <a class="navbar-brand d-flex align-items-center" href="/">
                <i class="bi bi-water me-2 fs-3"></i>
                <span class="fw-bold">Aqualink Automate</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/"><i class="bi bi-house-door me-1"></i>Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link active" href="/equipment"><i class="bi bi-bar-chart me-1"></i>Statistics</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/version"><i class="bi bi-info-circle me-1"></i>About</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="container-fluid px-4 py-4">
        
        <!-- Page Header -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h2 class="mb-1">
                            <i class="bi bi-bar-chart-fill text-primary me-2"></i>
                            Equipment Statistics
                        </h2>
                        <p class="text-muted mb-0">Real-time performance metrics and message statistics</p>
                    </div>
                    <div>
                        <button class="btn btn-outline-primary" id="refreshStats">
                            <i class="bi bi-arrow-clockwise me-1"></i>Refresh
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Device Information -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card shadow-sm border-0">
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <h6 class="text-muted mb-3">
                                    <i class="bi bi-cpu me-1"></i>Controller Information
                                </h6>
                                <div class="row">
                                    <div class="col-6">
                                        <small class="text-muted">Model:</small>
                                        <p class="mb-2"><strong id="deviceModel">Loading...</strong></p>
                                    </div>
                                    <div class="col-6">
                                        <small class="text-muted">Firmware:</small>
                                        <p class="mb-2"><strong id="deviceFirmware">-</strong></p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <h6 class="text-muted mb-3">
                                    <i class="bi bi-clock-history me-1"></i>Connection Status
                                </h6>
                                <div class="d-flex align-items-center">
                                    <span class="status-dot connected me-2" id="statsConnectionDot"></span>
                                    <span id="statsConnectionStatus">Connected</span>
                                    <small class="text-muted ms-3">Last update: <span id="statsLastUpdate">-</span></small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Serial Bandwidth Metrics -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-transparent border-0">
                        <h5 class="mb-0">
                            <i class="bi bi-speedometer2 text-primary me-2"></i>
                            Serial Port Utilization
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>Direction</th>
                                        <th>Total Bytes</th>
                                        <th>Util % (1s)</th>
                                        <th>Util % (30s)</th>
                                        <th>Util % (5m)</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>
                                            <i class="bi bi-download text-success me-1"></i>
                                            <strong>Read</strong>
                                        </td>
                                        <td id="readTotalBytes">-</td>
                                        <td>
                                            <span id="readUtil1s" class="badge bg-light text-dark">-</span>
                                        </td>
                                        <td>
                                            <span id="readUtil30s" class="badge bg-light text-dark">-</span>
                                        </td>
                                        <td>
                                            <span id="readUtil5m" class="badge bg-light text-dark">-</span>
                                        </td>
                                        <td>
                                            <div class="progress" style="height: 20px; width: 100px;">
                                                <div id="readUtilBar" class="progress-bar bg-success" role="progressbar" style="width: 0%">0%</div>
                                            </div>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <i class="bi bi-upload text-primary me-1"></i>
                                            <strong>Write</strong>
                                        </td>
                                        <td id="writeTotalBytes">-</td>
                                        <td>
                                            <span id="writeUtil1s" class="badge bg-light text-dark">-</span>
                                        </td>
                                        <td>
                                            <span id="writeUtil30s" class="badge bg-light text-dark">-</span>
                                        </td>
                                        <td>
                                            <span id="writeUtil5m" class="badge bg-light text-dark">-</span>
                                        </td>
                                        <td>
                                            <div class="progress" style="height: 20px; width: 100px;">
                                                <div id="writeUtilBar" class="progress-bar bg-primary" role="progressbar" style="width: 0%">0%</div>
                                            </div>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Utilization Chart -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-transparent border-0">
                        <h5 class="mb-0">
                            <i class="bi bi-graph-up text-primary me-2"></i>
                            Real-time Utilization Graph
                        </h5>
                    </div>
                    <div class="card-body">
                        <canvas id="utilizationChart" height="80"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <!-- Message Statistics -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-transparent border-0">
                        <h5 class="mb-0">
                            <i class="bi bi-envelope-fill text-primary me-2"></i>
                            Message Statistics
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-striped table-hover" id="messageStatsTable">
                                <thead>
                                    <tr>
                                        <th>Message ID</th>
                                        <th>Count</th>
                                        <th>Frequency</th>
                                        <th>Last Seen</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td colspan="4" class="text-center text-muted py-4">
                                            <div class="spinner-border spinner-border-sm me-2" role="status"></div>
                                            Loading message statistics...
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <!-- Footer -->
    <footer class="bg-light mt-5 py-4">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-start mb-3 mb-md-0">
                    <small class="text-muted">
                        <i class="bi bi-code-square me-1"></i>
                        Version <span id="appVersion">-</span>
                    </small>
                </div>
                <div class="col-md-6 text-center text-md-end">
                    <small class="text-muted">
                        <a href="/" class="text-decoration-none me-3">Dashboard</a>
                        <a href="/version" class="text-decoration-none">About</a>
                    </small>
                </div>
            </div>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns@3.0.0/dist/chartjs-adapter-date-fns.bundle.min.js"></script>
    <script src="scripts/equipment-stats.js"></script>
</body>
</html>
