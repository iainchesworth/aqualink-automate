<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="styles/pool-monitor.css" rel="stylesheet">

    <title>Aqualink Automate - Pool Monitor</title>
</head>
<body>
    <!-- Top Navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-gradient-primary sticky-top shadow">
        <div class="container-fluid">
            <a class="navbar-brand d-flex align-items-center" href="/">
                <i class="bi bi-water me-2 fs-3"></i>
                <span class="fw-bold">Aqualink Automate</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link active" href="/"><i class="bi bi-house-door me-1"></i>Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/equipment"><i class="bi bi-bar-chart me-1"></i>Statistics</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/version"><i class="bi bi-info-circle me-1"></i>About</a>
                    </li>
                </ul>
                <div class="navbar-text ms-3 d-none d-lg-block">
                    <span class="badge bg-light text-dark" id="lastUpdateTime">
                        <i class="bi bi-clock me-1"></i>Connecting...
                    </span>
                </div>
            </div>
        </div>
    </nav>

    <!-- System Status Banner -->
    <div class="container-fluid mt-3">
        <div id="systemStatusBanner" class="alert alert-warning alert-dismissible fade show" role="alert" style="display: none;">
            <div class="d-flex align-items-center">
                <i class="bi bi-exclamation-triangle-fill me-2 fs-4"></i>
                <div>
                    <strong id="bannerTitle">System Status</strong>
                    <p class="mb-0" id="bannerMessage">Loading system information...</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="container-fluid px-4 py-3">

        <!-- Controller Info Card -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card shadow-sm border-0">
                    <div class="card-body d-flex justify-content-between align-items-center py-2">
                        <div>
                            <span class="text-muted small">Controller:</span>
                            <strong id="controllerType" class="ms-2">Loading...</strong>
                            <span class="text-muted small ms-3">Firmware:</span>
                            <strong id="controllerFirmware" class="ms-2">-</strong>
                        </div>
                        <div class="text-end">
                            <span class="text-muted small">System Time:</span>
                            <strong id="systemDateTime" class="ms-2">--:--:--</strong>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Quick Status Cards -->
        <div class="row g-3 mb-4">
            <!-- Pool Temperature Card -->
            <div class="col-lg-3 col-md-6">
                <div class="card status-card shadow-sm border-0 h-100">
                    <div class="card-body text-center">
                        <div class="status-icon mb-3">
                            <i class="bi bi-thermometer-half text-primary"></i>
                        </div>
                        <h6 class="text-muted mb-2">Pool Temperature</h6>
                        <h2 class="mb-0 fw-bold" id="poolTemp">--</h2>
                        <div class="mt-2">
                            <span class="badge bg-info" id="poolHeatStatus">Unknown</span>
                        </div>
                        <div class="mt-2">
                            <small class="text-muted" style="font-size: 0.7rem;">Requires filter pump in pool mode</small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Spa Temperature Card -->
            <div class="col-lg-3 col-md-6">
                <div class="card status-card shadow-sm border-0 h-100">
                    <div class="card-body text-center">
                        <div class="status-icon mb-3">
                            <i class="bi bi-thermometer-high text-danger"></i>
                        </div>
                        <h6 class="text-muted mb-2">Spa Temperature</h6>
                        <h2 class="mb-0 fw-bold" id="spaTemp">--</h2>
                        <div class="mt-2">
                            <span class="badge bg-info" id="spaHeatStatus">Unknown</span>
                        </div>
                        <div class="mt-2">
                            <small class="text-muted" style="font-size: 0.7rem;">Requires filter pump in spa mode</small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Air Temperature Card -->
            <div class="col-lg-3 col-md-6">
                <div class="card status-card shadow-sm border-0 h-100">
                    <div class="card-body text-center">
                        <div class="status-icon mb-3">
                            <i class="bi bi-wind text-info"></i>
                        </div>
                        <h6 class="text-muted mb-2">Air Temperature</h6>
                        <h2 class="mb-0 fw-bold" id="airTemp">--</h2>
                        <div class="mt-2">
                            <span class="badge bg-light text-dark">Ambient</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- System Status Card -->
            <div class="col-lg-3 col-md-6">
                <div class="card status-card shadow-sm border-0 h-100">
                    <div class="card-body text-center">
                        <div class="status-icon mb-3">
                            <i class="bi bi-power text-success" id="systemStatusIcon"></i>
                        </div>
                        <h6 class="text-muted mb-2">System Status</h6>
                        <h5 class="mb-0 fw-bold" id="systemStatus">Initializing</h5>
                        <div class="mt-2">
                            <div class="connection-indicator">
                                <span class="status-dot" id="connectionStatus"></span>
                                <small class="text-muted ms-1" id="connectionText">Connecting</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Water Chemistry -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-transparent border-0 d-flex align-items-center">
                        <i class="bi bi-droplet-half text-primary me-2 fs-4"></i>
                        <h5 class="mb-0">Water Chemistry</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-4">
                            <div class="col-md-4">
                                <div class="chemistry-item p-3 rounded text-center">
                                    <i class="bi bi-activity fs-2 text-warning mb-2"></i>
                                    <h6 class="text-muted mb-1">pH Level</h6>
                                    <h3 class="mb-0 fw-bold" id="phLevel">-</h3>
                                    <div class="progress mt-2" style="height: 6px;">
                                        <div class="progress-bar bg-warning" role="progressbar" id="phProgress" style="width: 0%"></div>
                                    </div>
                                    <small class="text-muted">Target: 7.2 - 7.8</small>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="chemistry-item p-3 rounded text-center">
                                    <i class="bi bi-lightning-charge fs-2 text-success mb-2"></i>
                                    <h6 class="text-muted mb-1">ORP (Oxidation)</h6>
                                    <h3 class="mb-0 fw-bold" id="orpLevel">-</h3>
                                    <div class="progress mt-2" style="height: 6px;">
                                        <div class="progress-bar bg-success" role="progressbar" id="orpProgress" style="width: 0%"></div>
                                    </div>
                                    <small class="text-muted">Target: 700 - 750 mV</small>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="chemistry-item p-3 rounded text-center">
                                    <i class="bi bi-droplet-half fs-2 text-info mb-2"></i>
                                    <h6 class="text-muted mb-1">Salt Level</h6>
                                    <h3 class="mb-0 fw-bold" id="saltLevel">-</h3>
                                    <div class="progress mt-2" style="height: 6px;">
                                        <div class="progress-bar bg-info" role="progressbar" id="saltProgress" style="width: 0%"></div>
                                    </div>
                                    <small class="text-muted">Target: 3800 - 4200 ppm</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Equipment Controls -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-transparent border-0 d-flex align-items-center justify-content-between">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-toggles text-primary me-2 fs-4"></i>
                            <h5 class="mb-0">Equipment Controls</h5>
                        </div>
                        <button class="btn btn-sm btn-outline-secondary" id="refreshButtons" title="Refresh">
                            <i class="bi bi-arrow-clockwise"></i>
                        </button>
                    </div>
                    <div class="card-body">
                        <div id="equipmentButtons" class="row g-3">
                            <!-- Buttons will be dynamically loaded here -->
                            <div class="col-12 text-center py-5">
                                <div class="spinner-border text-primary" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                                <p class="text-muted mt-3">Loading equipment controls...</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Main Action Buttons -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-transparent border-0 d-flex align-items-center">
                        <i class="bi bi-gear-fill text-primary me-2 fs-4"></i>
                        <h5 class="mb-0">Main Functions</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-lg-3 col-md-6">
                                <button class="btn btn-action w-100" id="spaHeatBtn">
                                    <i class="bi bi-fire"></i>
                                    <span>Spa Heat</span>
                                    <small class="status-text" id="spaHeatBtnStatus">Unavailable</small>
                                </button>
                            </div>
                            <div class="col-lg-3 col-md-6">
                                <button class="btn btn-action w-100" id="poolHeatBtn">
                                    <i class="bi bi-sun"></i>
                                    <span>Pool Heat</span>
                                    <small class="status-text" id="poolHeatBtnStatus">Unavailable</small>
                                </button>
                            </div>
                            <div class="col-lg-3 col-md-6">
                                <button class="btn btn-action w-100" id="solarHeatBtn">
                                    <i class="bi bi-brightness-high"></i>
                                    <span>Solar Heat</span>
                                    <small class="status-text" id="solarHeatBtnStatus">Unavailable</small>
                                </button>
                            </div>
                            <div class="col-lg-3 col-md-6">
                                <button class="btn btn-action w-100" id="userBtn">
                                    <i class="bi bi-person-gear"></i>
                                    <span>User Function</span>
                                    <small class="status-text" id="userBtnStatus">Unavailable</small>
                                </button>
                            </div>
                            <div class="col-lg-3 col-md-6">
                                <button class="btn btn-action w-100" id="cleanBtn">
                                    <i class="bi bi-brush"></i>
                                    <span>Cleaner</span>
                                    <small class="status-text" id="cleanBtnStatus">Unavailable</small>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <!-- Footer -->
    <footer class="bg-light mt-5 py-4">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-start mb-3 mb-md-0">
                    <small class="text-muted">
                        <i class="bi bi-code-square me-1"></i>
                        Version <span id="appVersion">-</span>
                        <span id="gitInfo" class="ms-2"></span>
                    </small>
                </div>
                <div class="col-md-6 text-center text-md-end">
                    <small class="text-muted">
                        <a href="/LICENSE.txt" class="text-decoration-none me-3">License</a>
                        <a href="https://github.com/aqualink-automate" class="text-decoration-none" target="_blank">
                            <i class="bi bi-github me-1"></i>GitHub
                        </a>
                    </small>
                </div>
            </div>
        </div>
    </footer>

    <!-- Toast Notifications Container -->
    <div class="toast-container position-fixed bottom-0 end-0 p-3">
        <div id="notificationToast" class="toast" role="alert">
            <div class="toast-header">
                <i class="bi bi-bell-fill me-2"></i>
                <strong class="me-auto" id="toastTitle">Notification</strong>
                <small id="toastTime">Now</small>
                <button type="button" class="btn-close" data-bs-dismiss="toast"></button>
            </div>
            <div class="toast-body" id="toastMessage">
                Message here
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="scripts/pool-monitor.js"></script>
</body>
</html>