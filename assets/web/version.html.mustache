<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="styles/pool-monitor.css" rel="stylesheet">
    
    <title>Aqualink Automate - About</title>
</head>
<body>
    <!-- Top Navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-gradient-primary sticky-top shadow">
        <div class="container-fluid">
            <a class="navbar-brand d-flex align-items-center" href="/">
                <i class="bi bi-water me-2 fs-3"></i>
                <span class="fw-bold">Aqualink Automate</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/"><i class="bi bi-house-door me-1"></i>Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/equipment"><i class="bi bi-bar-chart me-1"></i>Statistics</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link active" href="/version"><i class="bi bi-info-circle me-1"></i>About</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="container py-5">
        
        <!-- Header -->
        <div class="row mb-5">
            <div class="col-12 text-center">
                <i class="bi bi-water text-primary" style="font-size: 4rem;"></i>
                <h1 class="mt-3 fw-bold">Aqualink Automate</h1>
                <p class="lead text-muted">Pool Automation System</p>
            </div>
        </div>

        <!-- Software Version Card -->
        <div class="row mb-4">
            <div class="col-lg-8 mx-auto">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-transparent border-0">
                        <h5 class="mb-0">
                            <i class="bi bi-code-square text-primary me-2"></i>
                            Software Version
                        </h5>
                    </div>
                    <div class="card-body">
                        <div id="softwareVersionContent" class="text-center py-4">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Git Information Card -->
        <div class="row mb-4" id="gitInfoCard" style="display: none;">
            <div class="col-lg-8 mx-auto">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-transparent border-0">
                        <h5 class="mb-0">
                            <i class="bi bi-git text-primary me-2"></i>
                            Git Information
                        </h5>
                    </div>
                    <div class="card-body">
                        <div id="gitInfoContent"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Equipment Version Card -->
        <div class="row mb-4">
            <div class="col-lg-8 mx-auto">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-transparent border-0">
                        <h5 class="mb-0">
                            <i class="bi bi-cpu text-primary me-2"></i>
                            Equipment Information
                        </h5>
                    </div>
                    <div class="card-body">
                        <div id="equipmentVersionContent" class="text-center py-4">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Features Card -->
        <div class="row mb-4">
            <div class="col-lg-8 mx-auto">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-transparent border-0">
                        <h5 class="mb-0">
                            <i class="bi bi-star text-primary me-2"></i>
                            Features
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-4">
                            <div class="col-md-6">
                                <div class="d-flex">
                                    <i class="bi bi-check-circle-fill text-success me-3 fs-4"></i>
                                    <div>
                                        <strong>Real-time Monitoring</strong>
                                        <p class="text-muted mb-0 small">Live temperature, chemistry, and equipment status updates</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="d-flex">
                                    <i class="bi bi-check-circle-fill text-success me-3 fs-4"></i>
                                    <div>
                                        <strong>Remote Control</strong>
                                        <p class="text-muted mb-0 small">Control pool equipment from anywhere</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="d-flex">
                                    <i class="bi bi-check-circle-fill text-success me-3 fs-4"></i>
                                    <div>
                                        <strong>WebSocket Support</strong>
                                        <p class="text-muted mb-0 small">Instant updates without page refresh</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="d-flex">
                                    <i class="bi bi-check-circle-fill text-success me-3 fs-4"></i>
                                    <div>
                                        <strong>Performance Metrics</strong>
                                        <p class="text-muted mb-0 small">Detailed statistics and utilization graphs</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="d-flex">
                                    <i class="bi bi-check-circle-fill text-success me-3 fs-4"></i>
                                    <div>
                                        <strong>Responsive Design</strong>
                                        <p class="text-muted mb-0 small">Works on desktop, tablet, and mobile devices</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="d-flex">
                                    <i class="bi bi-check-circle-fill text-success me-3 fs-4"></i>
                                    <div>
                                        <strong>REST API</strong>
                                        <p class="text-muted mb-0 small">Full-featured API for integration</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <!-- Footer -->
    <footer class="bg-light mt-5 py-4">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-start mb-3 mb-md-0">
                    <small class="text-muted">
                        © 2024 Aqualink Automate
                    </small>
                </div>
                <div class="col-md-6 text-center text-md-end">
                    <small class="text-muted">
                        <a href="/" class="text-decoration-none me-3">Dashboard</a>
                        <a href="/equipment" class="text-decoration-none me-3">Statistics</a>
                        <a href="https://github.com/aqualink-automate" class="text-decoration-none" target="_blank">
                            <i class="bi bi-github me-1"></i>GitHub
                        </a>
                    </small>
                </div>
            </div>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        async function loadVersionInfo() {
            try {
                const response = await fetch('/api/version');
                const data = await response.json();
                
                // Display software version
                if (data.software_version) {
                    const sv = data.software_version;
                    document.getElementById('softwareVersionContent').innerHTML = `
                        <div class="row g-3">
                            <div class="col-md-6">
                                <small class="text-muted d-block mb-1">Project Name</small>
                                <strong class="fs-5">${sv.name || '-'}</strong>
                            </div>
                            <div class="col-md-6">
                                <small class="text-muted d-block mb-1">Version</small>
                                <strong class="fs-5">${sv.version || '-'}</strong>
                            </div>
                            <div class="col-12">
                                <small class="text-muted d-block mb-1">Description</small>
                                <p class="mb-0">${sv.description || '-'}</p>
                            </div>
                            ${sv.homepage ? `
                            <div class="col-12">
                                <small class="text-muted d-block mb-1">Homepage</small>
                                <a href="${sv.homepage}" target="_blank" class="text-decoration-none">
                                    ${sv.homepage}
                                    <i class="bi bi-box-arrow-up-right ms-1"></i>
                                </a>
                            </div>
                            ` : ''}
                        </div>
                    `;
                }
                
                // Display git information
                if (data.git_info) {
                    const gi = data.git_info;
                    document.getElementById('gitInfoCard').style.display = 'block';
                    document.getElementById('gitInfoContent').innerHTML = `
                        <div class="row g-3">
                            <div class="col-md-6">
                                <small class="text-muted d-block mb-1">Commit SHA</small>
                                <code class="fs-6">${gi.commit_sha1 || '-'}</code>
                            </div>
                            <div class="col-md-6">
                                <small class="text-muted d-block mb-1">Commit Date</small>
                                <strong>${gi.commit_date || '-'}</strong>
                            </div>
                            <div class="col-12">
                                <small class="text-muted d-block mb-1">Uncommitted Changes</small>
                                ${gi.uncommitted_changes 
                                    ? '<span class="badge bg-warning">Yes</span>' 
                                    : '<span class="badge bg-success">No</span>'
                                }
                            </div>
                        </div>
                    `;
                }
                
            } catch (error) {
                console.error('Failed to load version info:', error);
                document.getElementById('softwareVersionContent').innerHTML = `
                    <div class="alert alert-danger" role="alert">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        Failed to load version information
                    </div>
                `;
            }
        }

        async function loadEquipmentVersion() {
            try {
                const response = await fetch('/api/equipment/version');
                const data = await response.json();
                
                document.getElementById('equipmentVersionContent').innerHTML = `
                    <div class="row g-3">
                        <div class="col-md-6">
                            <small class="text-muted d-block mb-1">Controller Type</small>
                            <strong class="fs-5">${data.type || 'Unknown'}</strong>
                        </div>
                        <div class="col-md-6">
                            <small class="text-muted d-block mb-1">Firmware Version</small>
                            <strong class="fs-5">${data.firmware || '-'}</strong>
                        </div>
                        ${data.model ? `
                        <div class="col-12">
                            <small class="text-muted d-block mb-1">Model</small>
                            <p class="mb-0">${data.model}</p>
                        </div>
                        ` : ''}
                    </div>
                `;
                
            } catch (error) {
                console.error('Failed to load equipment version:', error);
                document.getElementById('equipmentVersionContent').innerHTML = `
                    <div class="alert alert-warning" role="alert">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        Equipment information not available
                    </div>
                `;
            }
        }

        // Load data when page loads
        document.addEventListener('DOMContentLoaded', () => {
            loadVersionInfo();
            loadEquipmentVersion();
        });
    </script>
</body>
</html>
