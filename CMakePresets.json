{
  "version": 9,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 31,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "core",
      "hidden": true,
      "binaryDir": "${sourceDir}/build/${presetName}",
      "installDir": "${sourceDir}/install/${presetName}",
      "toolchainFile": "${sourceDir}/deps/vcpkg/scripts/buildsystems/vcpkg.cmake",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_CONFIGURATION_TYPES": "Debug;Release",
        "ENABLE_BENCHMARKS": "ON",
        "ENABLE_COVERAGE": "OFF",
        "ENABLE_TESTS": "ON",
        "ENABLE_CLANG_TIDY": "OFF",
        "ENABLE_PVS_STUDIO": "OFF",
        "ENABLE_PROFILING": "ON",
        "ENABLE_SANITIZERS": "OFF",
        "ENABLE_ASIO_TRACKING": "ON",
        "SANITIZE_ADDRESS": "OFF",
        "SANITIZE_MEMORY": "OFF",
        "SANITIZE_THREAD": "OFF",
        "SANITIZE_UNDEFINED": "OFF",
        "USE_SONARQUBE": "OFF",
        "VCPKG_OVERLAY_TRIPLETS": "${sourceDir}/cmake/vcpkg/triplets"
      },
      "environment": {
        "VCPKG_KEEP_ENV_VARS": "INCLUDE,LIB,LIBPATH,PATH"
      }
    },
    {
      "name": "debug",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ENABLE_PROFILING": "OFF",
        "ENABLE_SANITIZERS": "ON",
        "ENABLE_CLANG_TIDY": "ON",
        "SANITIZE_ADDRESS": "ON",
        "SANITIZE_UNDEFINED": "ON"
      }
    },
    {
      "name": "release",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },

    {
      "name": "config-windows-msvc",
      "inherits": [ "core", "release" ],
      "displayName": "Windows MSVC Release",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows-msvc",
        "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/windows.msvc.toolchain.cmake"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "config-windows-msvc-debug",
      "inherits": [ "core" ],
      "displayName": "Windows MSVC Debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "VCPKG_TARGET_TRIPLET": "x64-windows-msvc",
        "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/windows.msvc.toolchain.cmake",
        "ENABLE_PROFILING": "OFF",
        "ENABLE_SANITIZERS": "ON",
        "ENABLE_CLANG_TIDY": "ON",
        "SANITIZE_ADDRESS": "ON",
        "SANITIZE_UNDEFINED": "ON"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },

    {
      "name": "config-windows-msvc-coverage",
      "inherits": [ "core" ],
      "displayName": "Windows MSVC Coverage",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "VCPKG_TARGET_TRIPLET": "x64-windows-msvc",
        "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/windows.msvc.toolchain.cmake",
        "ENABLE_PROFILING": "OFF",
        "ENABLE_BENCHMARKS": "OFF",
        "ENABLE_COVERAGE": "ON",
        "ENABLE_SANITIZERS": "OFF"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },

    {
      "name": "config-windows-llvm",
      "inherits": [ "core", "release" ],
      "displayName": "Windows LLVM Release",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows-llvm",
        "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/windows.llvm.toolchain.cmake"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "config-windows-llvm-debug",
      "inherits": [ "core" ],
      "displayName": "Windows LLVM Debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "VCPKG_TARGET_TRIPLET": "x64-windows-llvm",
        "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/windows.llvm.toolchain.cmake",
        "ENABLE_PROFILING": "OFF",
        "ENABLE_SANITIZERS": "ON",
        "ENABLE_CLANG_TIDY": "ON",
        "SANITIZE_ADDRESS": "ON",
        "SANITIZE_UNDEFINED": "ON"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },

    {
      "name": "config-linux-gcc",
      "inherits": [ "core", "release" ],
      "displayName": "Linux GCC Release",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-linux-gcc",
        "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/linux.gcc.toolchain.cmake"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "config-linux-gcc-debug",
      "inherits": [ "core" ],
      "displayName": "Linux GCC Debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "VCPKG_TARGET_TRIPLET": "x64-linux-gcc",
        "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/linux.gcc.toolchain.cmake",
        "ENABLE_PROFILING": "OFF",
        "ENABLE_SANITIZERS": "ON",
        "ENABLE_CLANG_TIDY": "ON",
        "SANITIZE_ADDRESS": "ON",
        "SANITIZE_UNDEFINED": "ON"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "config-linux-gcc-coverage",
      "inherits": [ "core" ],
      "displayName": "Linux GCC Coverage",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "VCPKG_TARGET_TRIPLET": "x64-linux-gcc",
        "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/linux.gcc.toolchain.cmake",
        "ENABLE_PROFILING": "OFF",
        "ENABLE_BENCHMARKS": "OFF",
        "ENABLE_COVERAGE": "ON",
        "ENABLE_SANITIZERS": "OFF"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },

    {
      "name": "config-linux-llvm",
      "inherits": [ "core", "release" ],
      "displayName": "Linux LLVM Release",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-linux-llvm",
        "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/linux.llvm.toolchain.cmake"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "config-linux-llvm-debug",
      "inherits": [ "core" ],
      "displayName": "Linux LLVM Debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "VCPKG_TARGET_TRIPLET": "x64-linux-llvm",
        "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/linux.llvm.toolchain.cmake",
        "ENABLE_PROFILING": "OFF",
        "ENABLE_SANITIZERS": "ON",
        "ENABLE_CLANG_TIDY": "ON",
        "SANITIZE_ADDRESS": "ON",
        "SANITIZE_UNDEFINED": "ON"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },

    {
      "name": "config-macos-llvm",
      "inherits": [ "core", "release" ],
      "displayName": "macOS LLVM Release",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "arm64-macos-llvm",
        "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/macos.llvm.toolchain.cmake"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    },
    {
      "name": "config-macos-llvm-debug",
      "inherits": [ "core" ],
      "displayName": "macOS LLVM Debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "VCPKG_TARGET_TRIPLET": "arm64-macos-llvm",
        "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/macos.llvm.toolchain.cmake",
        "ENABLE_PROFILING": "OFF",
        "ENABLE_SANITIZERS": "ON",
        "ENABLE_CLANG_TIDY": "ON",
        "SANITIZE_ADDRESS": "ON",
        "SANITIZE_UNDEFINED": "ON"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    }
  ],

  "buildPresets": [
    {
      "name": "build-windows-msvc",
      "configurePreset": "config-windows-msvc",
      "displayName": "Windows MSVC Release",
      "configuration": "Release"
    },
    {
      "name": "build-windows-msvc-debug",
      "configurePreset": "config-windows-msvc-debug",
      "displayName": "Windows MSVC Debug",
      "configuration": "Debug"
    },
    {
      "name": "build-windows-msvc-coverage",
      "configurePreset": "config-windows-msvc-coverage",
      "displayName": "Windows MSVC Coverage",
      "configuration": "Debug",
      "targets": [ "coverage-testaqualink-automate" ]
    },
    {
      "name": "build-windows-llvm",
      "configurePreset": "config-windows-llvm",
      "displayName": "Windows LLVM Release",
      "configuration": "Release"
    },
    {
      "name": "build-windows-llvm-debug",
      "configurePreset": "config-windows-llvm-debug",
      "displayName": "Windows LLVM Debug",
      "configuration": "Debug"
    },
    {
      "name": "build-linux-gcc",
      "configurePreset": "config-linux-gcc",
      "displayName": "Linux GCC Release",
      "configuration": "Release"
    },
    {
      "name": "build-linux-gcc-debug",
      "configurePreset": "config-linux-gcc-debug",
      "displayName": "Linux GCC Debug",
      "configuration": "Debug"
    },
    {
      "name": "build-linux-gcc-coverage",
      "configurePreset": "config-linux-gcc-coverage",
      "displayName": "Linux GCC Coverage",
      "configuration": "Debug",
      "targets": [ "coverage-testaqualink-automate" ]
    },
    {
      "name": "build-linux-llvm",
      "configurePreset": "config-linux-llvm",
      "displayName": "Linux LLVM Release",
      "configuration": "Release"
    },
    {
      "name": "build-linux-llvm-debug",
      "configurePreset": "config-linux-llvm-debug",
      "displayName": "Linux LLVM Debug",
      "configuration": "Debug"
    },
    {
      "name": "build-macos-llvm",
      "configurePreset": "config-macos-llvm",
      "displayName": "macOS LLVM Release",
      "configuration": "Release"
    },
    {
      "name": "build-macos-llvm-debug",
      "configurePreset": "config-macos-llvm-debug",
      "displayName": "macOS LLVM Debug",
      "configuration": "Debug"
    }
  ],

  "testPresets": [
    {
      "name": "test-windows-msvc",
      "configurePreset": "config-windows-msvc",
      "displayName": "Windows MSVC Release Tests",
      "output": { "outputOnFailure": true },
      "execution": { "noTestsAction": "error", "stopOnFailure": false }
    },
    {
      "name": "test-windows-msvc-debug",
      "configurePreset": "config-windows-msvc-debug",
      "displayName": "Windows MSVC Debug Tests",
      "output": { "outputOnFailure": true },
      "execution": { "noTestsAction": "error", "stopOnFailure": false }
    },
    {
      "name": "test-windows-msvc-coverage",
      "configurePreset": "config-windows-msvc-coverage",
      "displayName": "Windows MSVC Coverage Tests",
      "output": { "outputOnFailure": true },
      "execution": { "noTestsAction": "error", "stopOnFailure": false }
    },
    {
      "name": "test-windows-llvm",
      "configurePreset": "config-windows-llvm",
      "displayName": "Windows LLVM Release Tests",
      "output": { "outputOnFailure": true },
      "execution": { "noTestsAction": "error", "stopOnFailure": false }
    },
    {
      "name": "test-windows-llvm-debug",
      "configurePreset": "config-windows-llvm-debug",
      "displayName": "Windows LLVM Debug Tests",
      "output": { "outputOnFailure": true },
      "execution": { "noTestsAction": "error", "stopOnFailure": false }
    },
    {
      "name": "test-linux-gcc",
      "configurePreset": "config-linux-gcc",
      "displayName": "Linux GCC Release Tests",
      "output": { "outputOnFailure": true },
      "execution": { "noTestsAction": "error", "stopOnFailure": false }
    },
    {
      "name": "test-linux-gcc-debug",
      "configurePreset": "config-linux-gcc-debug",
      "displayName": "Linux GCC Debug Tests",
      "output": { "outputOnFailure": true },
      "execution": { "noTestsAction": "error", "stopOnFailure": false }
    },
    {
      "name": "test-linux-gcc-coverage",
      "configurePreset": "config-linux-gcc-coverage",
      "displayName": "Linux GCC Coverage Tests",
      "output": { "outputOnFailure": true },
      "execution": { "noTestsAction": "error", "stopOnFailure": false }
    },
    {
      "name": "test-linux-llvm",
      "configurePreset": "config-linux-llvm",
      "displayName": "Linux LLVM Release Tests",
      "output": { "outputOnFailure": true },
      "execution": { "noTestsAction": "error", "stopOnFailure": false }
    },
    {
      "name": "test-linux-llvm-debug",
      "configurePreset": "config-linux-llvm-debug",
      "displayName": "Linux LLVM Debug Tests",
      "output": { "outputOnFailure": true },
      "execution": { "noTestsAction": "error", "stopOnFailure": false }
    },
    {
      "name": "test-macos-llvm",
      "configurePreset": "config-macos-llvm",
      "displayName": "macOS LLVM Release Tests",
      "output": { "outputOnFailure": true },
      "execution": { "noTestsAction": "error", "stopOnFailure": false }
    },
    {
      "name": "test-macos-llvm-debug",
      "configurePreset": "config-macos-llvm-debug",
      "displayName": "macOS LLVM Debug Tests",
      "output": { "outputOnFailure": true },
      "execution": { "noTestsAction": "error", "stopOnFailure": false }
    }
  ],

  "packagePresets": [
    {
      "name": "pack-windows-msvc",
      "displayName": "Windows MSVC Package",
      "configurePreset": "config-windows-msvc",
      "generators": [ "ZIP", "NSIS" ],
      "packageDirectory": "packages"
    },
    {
      "name": "pack-windows-llvm",
      "displayName": "Windows LLVM Package",
      "configurePreset": "config-windows-llvm",
      "generators": [ "ZIP", "NSIS" ],
      "packageDirectory": "packages"
    },
    {
      "name": "pack-linux-gcc",
      "displayName": "Linux GCC Package",
      "configurePreset": "config-linux-gcc",
      "generators": [ "TGZ", "DEB", "RPM" ],
      "packageDirectory": "packages"
    },
    {
      "name": "pack-linux-llvm",
      "displayName": "Linux LLVM Package",
      "configurePreset": "config-linux-llvm",
      "generators": [ "TGZ", "DEB", "RPM" ],
      "packageDirectory": "packages"
    },
    {
      "name": "pack-macos-llvm",
      "displayName": "macOS LLVM Package",
      "configurePreset": "config-macos-llvm",
      "generators": [ "TGZ", "DragNDrop" ],
      "packageDirectory": "packages"
    }
  ],

  "workflowPresets": [
    {
      "name": "ci-windows-msvc",
      "displayName": "Windows MSVC CI Workflow",
      "steps": [
        { "type": "configure", "name": "config-windows-msvc" },
        { "type": "build", "name": "build-windows-msvc" },
        { "type": "test", "name": "test-windows-msvc" },
        { "type": "package", "name": "pack-windows-msvc" }
      ]
    },
    {
      "name": "ci-windows-llvm",
      "displayName": "Windows LLVM CI Workflow",
      "steps": [
        { "type": "configure", "name": "config-windows-llvm" },
        { "type": "build", "name": "build-windows-llvm" },
        { "type": "test", "name": "test-windows-llvm" },
        { "type": "package", "name": "pack-windows-llvm" }
      ]
    },
    {
      "name": "ci-linux-gcc",
      "displayName": "Linux GCC CI Workflow",
      "steps": [
        { "type": "configure", "name": "config-linux-gcc" },
        { "type": "build", "name": "build-linux-gcc" },
        { "type": "test", "name": "test-linux-gcc" },
        { "type": "package", "name": "pack-linux-gcc" }
      ]
    },
    {
      "name": "ci-linux-llvm",
      "displayName": "Linux LLVM CI Workflow",
      "steps": [
        { "type": "configure", "name": "config-linux-llvm" },
        { "type": "build", "name": "build-linux-llvm" },
        { "type": "test", "name": "test-linux-llvm" },
        { "type": "package", "name": "pack-linux-llvm" }
      ]
    },
    {
      "name": "ci-macos-llvm",
      "displayName": "macOS LLVM CI Workflow",
      "steps": [
        { "type": "configure", "name": "config-macos-llvm" },
        { "type": "build", "name": "build-macos-llvm" },
        { "type": "test", "name": "test-macos-llvm" },
        { "type": "package", "name": "pack-macos-llvm" }
      ]
    },
    {
      "name": "ci-windows-coverage",
      "displayName": "Windows MSVC Coverage Analysis",
      "steps": [
        { "type": "configure", "name": "config-windows-msvc-coverage" },
        { "type": "build", "name": "build-windows-msvc-coverage" },
        { "type": "test", "name": "test-windows-msvc-coverage" }
      ]
    },
    {
      "name": "ci-coverage",
      "displayName": "Linux Coverage Analysis",
      "steps": [
        { "type": "configure", "name": "config-linux-gcc-coverage" },
        { "type": "build", "name": "build-linux-gcc-coverage" },
        { "type": "test", "name": "test-linux-gcc-coverage" }
      ]
    }
  ]
}
