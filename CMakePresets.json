        "rhs": "Darwin"
      }
    },

    {
      "name": "config-windows-msvc-profiling",
      "inherits": [ "profiling", "config-windows-msvc" ],
      "displayName": "Windows MSVC Profiling (RelWithDebInfo)",
      "description": "Profiling-enabled Windows MSVC build. Tracy is always compiled in; VTune/uProf compile in when their SDKs are found. Select the backend at runtime with --profiler tracy|vtune|uprof."
    },
    {
      "name": "config-windows-llvm-profiling",
      "inherits": [ "profiling", "config-windows-llvm" ],
      "displayName": "Windows LLVM Profiling (RelWithDebInfo)",
      "description": "Profiling-enabled Windows LLVM build (see config-windows-msvc-profiling)."
    },
    {
      "name": "config-linux-gcc-profiling",
      "inherits": [ "profiling", "config-linux-gcc" ],
      "displayName": "Linux GCC Profiling (RelWithDebInfo)",
      "description": "Profiling-enabled Linux GCC build (see config-windows-msvc-profiling)."
    },
    {
      "name": "config-linux-llvm-profiling",
      "inherits": [ "profiling", "config-linux-llvm" ],
      "displayName": "Linux LLVM Profiling (RelWithDebInfo)",
      "description": "Profiling-enabled Linux LLVM build (see config-windows-msvc-profiling)."
    },
    {
      "name": "config-macos-llvm-profiling",
      "inherits": [ "profiling", "config-macos-llvm" ],
      "displayName": "macOS LLVM Profiling (RelWithDebInfo)",
      "description": "Profiling-enabled macOS LLVM build (see config-windows-msvc-profiling)."
    },

    {
      "name": "config-windows-msvc-diagnostic",
      "inherits": [ "profiling", "config-windows-msvc" ],
      "displayName": "Windows MSVC Diagnostic (network-hardened profiling)",
      "description": "Hardened profiling build: same as config-windows-msvc-profiling but the Tracy client is built (via the -diagnostic triplet) with TRACY_ONLY_LOCALHOST + TRACY_NO_BROADCAST, so the profiler data port binds to loopback only and emits no UDP discovery beacon. Suitable for an always-attachable beta/field-diagnostic build. NOTE: the distinct triplet triggers a one-time vcpkg rebuild into its own installed tree.",
      "cacheVariables": { "VCPKG_TARGET_TRIPLET": "x64-windows-msvc-diagnostic" }
    },
    {
      "name": "config-windows-llvm-diagnostic",
      "inherits": [ "profiling", "config-windows-llvm" ],
      "displayName": "Windows LLVM Diagnostic (network-hardened profiling)",
      "description": "Hardened profiling build (see config-windows-msvc-diagnostic).",
      "cacheVariables": { "VCPKG_TARGET_TRIPLET": "x64-windows-llvm-diagnostic" }
    },
    {
      "name": "config-linux-gcc-diagnostic",
      "inherits": [ "profiling", "config-linux-gcc" ],
      "displayName": "Linux GCC Diagnostic (network-hardened profiling)",
      "description": "Hardened profiling build (see config-windows-msvc-diagnostic).",
      "cacheVariables": { "VCPKG_TARGET_TRIPLET": "x64-linux-gcc-diagnostic" }
    },
    {
      "name": "config-linux-llvm-diagnostic",
      "inherits": [ "profiling", "config-linux-llvm" ],
      "displayName": "Linux LLVM Diagnostic (network-hardened profiling)",
      "description": "Hardened profiling build (see config-windows-msvc-diagnostic).",
      "cacheVariables": { "VCPKG_TARGET_TRIPLET": "x64-linux-llvm-diagnostic" }
    },
    {
      "name": "config-macos-llvm-diagnostic",
      "inherits": [ "profiling", "config-macos-llvm" ],
      "displayName": "macOS LLVM Diagnostic (network-hardened profiling)",
      "description": "Hardened profiling build (see config-windows-msvc-diagnostic).",
      "cacheVariables": { "VCPKG_TARGET_TRIPLET": "arm64-macos-llvm-diagnostic" }
    }
  ],

