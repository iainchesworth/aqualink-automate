{
  "version": 9,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 31,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "core",
      "hidden": true,
      "description": "Shared configuration for every platform/compiler preset. NOTE: VCPKG_CHAINLOAD_TOOLCHAIN_FILE is the single source of truth for the chainloaded compiler toolchain and is set per concrete preset here; the vcpkg overlay triplets must NOT also set it (avoids the platform-asymmetric duplication).",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "installDir": "${sourceDir}/install/${presetName}",
      "toolchainFile": "${sourceDir}/deps/vcpkg/scripts/buildsystems/vcpkg.cmake",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_CONFIGURATION_TYPES": "Debug;Release",
        "ENABLE_BENCHMARKS": "ON",
        "ENABLE_COVERAGE": "OFF",
        "ENABLE_TESTS": "ON",
        "ENABLE_CLANG_TIDY": "OFF",
        "ENABLE_PVS_STUDIO": "OFF",
        "ENABLE_PROFILING": "ON",
        "ENABLE_SANITIZERS": "OFF",
        "ENABLE_ASIO_TRACKING": "ON",
        "SANITIZE_ADDRESS": "OFF",
        "SANITIZE_MEMORY": "OFF",
        "SANITIZE_THREAD": "OFF",
        "SANITIZE_UNDEFINED": "OFF",
        "USE_SONARQUBE": "OFF",
        "VCPKG_OVERLAY_TRIPLETS": "${sourceDir}/cmake/vcpkg/triplets"
      },
      "environment": {
        "VCPKG_KEEP_ENV_VARS": "INCLUDE,LIB,LIBPATH,PATH"
      }
    },
    {
      "name": "debug",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ENABLE_PROFILING": "OFF",
        "ENABLE_SANITIZERS": "ON",
        "ENABLE_CLANG_TIDY": "ON",
        "SANITIZE_ADDRESS": "ON",
        "SANITIZE_UNDEFINED": "ON"
      }
    },
    {
      "name": "release",
      "hidden": true,
      "description": "Shared Release configuration. Profiling (Tracy/VTune/uProf instrumentation) is OFF here so the shipped release binary carries no profiler hooks. To capture traces use a dedicated profiling preset (e.g. config-windows-msvc-profiling) — NOT a debug preset (those also build with profiling OFF).",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "ENABLE_PROFILING": "OFF"
      }
    },
    {
      "name": "profiling",
      "hidden": true,
      "description": "Shared profiling configuration: ENABLE_PROFILING ON, built RelWithDebInfo (optimised + debug symbols, the right shape for a profiler) with sanitizers OFF (mutually exclusive with profiling). Combine with a concrete platform preset, e.g. config-windows-msvc-profiling. Tracy is always available (vcpkg); the Intel VTune and AMD uProf backends compile in only when their SDKs are found (set VTUNE_PROFILER_DIR / AMD_UPROF_SDK_PATH, or install to a default location).",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "ENABLE_PROFILING": "ON",
        "ENABLE_SANITIZERS": "OFF",
        "SANITIZE_ADDRESS": "OFF",
        "SANITIZE_UNDEFINED": "OFF"
      }
    },

    {
      "name": "config-windows-msvc",
      "inherits": [ "release", "core" ],
      "displayName": "Windows MSVC Release",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows-msvc",
        "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/windows.msvc.toolchain.cmake"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "config-windows-msvc-debug",
      "inherits": [ "debug", "core" ],
      "displayName": "Windows MSVC Debug",
      "description": "Windows MSVC Debug. Sanitizers are forced OFF here: under MSVC (cl.exe) the project sanitizer mechanism cannot apply ASan in a -MDd Debug build and UBSan is unsupported, so an 'ON' setting silently produced a NON-sanitized binary plus noisy per-target configure warnings. For a real sanitized Debug build use config-windows-llvm-debug (clang-cl). clang-tidy stays ON so this remains the static-analysis gate.",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows-msvc",
        "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/windows.msvc.toolchain.cmake",
        "ENABLE_SANITIZERS": "OFF",
        "SANITIZE_ADDRESS": "OFF",
        "SANITIZE_UNDEFINED": "OFF"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },

    {
      "name": "config-windows-msvc-coverage",
      "inherits": [ "core" ],
      "displayName": "Windows MSVC Coverage",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "VCPKG_TARGET_TRIPLET": "x64-windows-msvc",
        "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/windows.msvc.toolchain.cmake",
        "ENABLE_PROFILING": "OFF",
        "ENABLE_BENCHMARKS": "OFF",
        "ENABLE_COVERAGE": "ON",
        "ENABLE_SANITIZERS": "OFF"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },

    {
      "name": "config-windows-llvm",
      "inherits": [ "release", "core" ],
      "displayName": "Windows LLVM Release",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows-llvm",
        "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/windows.llvm.toolchain.cmake"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "config-windows-llvm-debug",
      "inherits": [ "debug", "core" ],
      "displayName": "Windows LLVM Debug",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows-llvm",
        "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/windows.llvm.toolchain.cmake"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },

    {
      "name": "config-linux-gcc",
      "inherits": [ "release", "core" ],
      "displayName": "Linux GCC Release",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-linux-gcc",
        "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/linux.gcc.toolchain.cmake"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "config-linux-gcc-debug",
      "inherits": [ "debug", "core" ],
      "displayName": "Linux GCC Debug",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-linux-gcc",
        "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/linux.gcc.toolchain.cmake"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "config-linux-gcc-coverage",
      "inherits": [ "core" ],
      "displayName": "Linux GCC Coverage",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "VCPKG_TARGET_TRIPLET": "x64-linux-gcc",
        "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/linux.gcc.toolchain.cmake",
        "ENABLE_PROFILING": "OFF",
        "ENABLE_BENCHMARKS": "OFF",
        "ENABLE_COVERAGE": "ON",
        "ENABLE_SANITIZERS": "OFF"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },

    {
      "name": "config-linux-gcc-arm64",
      "inherits": [ "release", "core" ],
      "displayName": "Linux GCC Release (arm64)",
      "description": "Native arm64 (aarch64) release build for Raspberry Pi and other arm64 hosts. Runs on an aarch64 Linux runner; the triplet/toolchain select the target arch, so the host condition is still Linux.",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "arm64-linux-gcc",
        "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/linux.gcc.toolchain.cmake"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "config-linux-gcc-arm64-debug",
      "inherits": [ "debug", "core" ],
      "displayName": "Linux GCC Debug (arm64)",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "arm64-linux-gcc",
        "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/linux.gcc.toolchain.cmake"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },

    {
      "name": "config-linux-llvm",
      "inherits": [ "release", "core" ],
      "displayName": "Linux LLVM Release",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-linux-llvm",
        "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/linux.llvm.toolchain.cmake"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "config-linux-llvm-debug",
      "inherits": [ "debug", "core" ],
      "displayName": "Linux LLVM Debug",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-linux-llvm",
        "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/linux.llvm.toolchain.cmake"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },

    {
      "name": "config-macos-llvm",
      "inherits": [ "release", "core" ],
      "displayName": "macOS LLVM Release",
      "cacheVariables": {
