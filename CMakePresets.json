      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    },
    {
      "name": "config-macos-llvm-debug",
      "inherits": [ "debug", "core" ],
      "displayName": "macOS LLVM Debug",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "arm64-macos-llvm",
        "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/macos.llvm.toolchain.cmake"
