#!/bin/sh
# Aqualink Automate - Debian prerm
set -e

SERVICE=aqualink-automate.service

case "$1" in
    remove|deconfigure)
        if [ -d /run/systemd/system ]; then
            systemctl stop "$SERVICE" >/dev/null 2>&1 || true
            systemctl disable "$SERVICE" >/dev/null 2>&1 || true
        fi
        ;;
esac

exit 0
