#cloud-config
autoinstall:
  version: 1
  locale: en_US.UTF-8
  keyboard:
    layout: us
  identity:
    hostname: github-runner-linux
    username: runner
    password: "$6$KEA7cxu8APmlmNdY$6TSZKPrGWR7hp7LjPrfyUF0s.oAVQn4GQoq2CjhGOdqfTikfXE7.CVEq0FXyg6quYYFxZvCu5kr42i8b4tPXH/"
  ssh:
    install-server: true
    allow-pw: true
  storage:
    layout:
      name: lvm
      # The VM has two disks: a smaller OS disk (disk0) and a larger data disk
      # (disk1, formatted later by 00-data-volume.sh). Pin the install to the
      # SMALLEST disk so the root LVM never lands on — or consumes — the data
      # disk. sizing-policy: all then fills the OS disk with the root LV.
      match:
        size: smallest
      sizing-policy: all
  packages:
    - open-vm-tools
    - openssh-server
  late-commands:
    - echo 'runner ALL=(ALL) NOPASSWD:ALL' > /target/etc/sudoers.d/runner
    - chmod 440 /target/etc/sudoers.d/runner
