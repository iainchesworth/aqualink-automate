#cloud-config
autoinstall:
  version: 1
  locale: en_US.UTF-8
  keyboard:
    layout: us
  identity:
    hostname: github-runner-linux
    username: runner
    password: "$6$KEA7cxu8APmlmNdY$6TSZKPrGWR7hp7LjPrfyUF0s.oAVQn4GQoq2CjhGOdqfTikfXE7.CVEq0FXyg6quYYFxZvCu5kr42i8b4tPXH/"
