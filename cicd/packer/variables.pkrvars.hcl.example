# vSphere connection settings
# Copy this file to variables.pkrvars.hcl and fill in your values.
# Do NOT commit variables.pkrvars.hcl — it is gitignored.

vcenter_server     = "vcenter.example.com"
vcenter_username   = "administrator@vsphere.local"
vcenter_insecure   = true
vcenter_datacenter = "Datacenter"
vcenter_cluster    = "Cluster"
vcenter_datastore  = "datastore1"
vcenter_network    = "VM Network"
vcenter_folder     = "Templates"

# ISO - local path (Packer uploads to datastore automatically)
iso_url = "ISOs/ubuntu-24.04.4-autoinstall.iso"

# Runner agent version
github_runner_version = "2.321.0"
