{
  "version": 9,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 31,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "config-windows-msvc-dev",
      "inherits": [ "config-windows-msvc-debug" ],
      "displayName": "Windows MSVC Debug with Sanitizers",
      "cacheVariables": {
        "CMAKE_CXX_FLAGS_INIT": "/fsanitize=address",
        "CMAKE_C_FLAGS_INIT": "/fsanitize=address",
        "ENABLE_SANITIZERS": "ON",
        "SANITIZE_ADDRESS": "ON"
      }
    },
    {
      "name": "config-windows-llvm-dev",
      "inherits": [ "config-windows-llvm-debug" ],
      "displayName": "Windows LLVM Debug with Sanitizers",
      "cacheVariables": {
        "ENABLE_SANITIZERS": "ON",
        "SANITIZE_ADDRESS": "ON"
      }
    },
    {
      "name": "config-windows-gcc-dev",
      "inherits": [ "config-windows-gcc-debug" ],
      "displayName": "Windows GCC Debug with Sanitizers",
      "cacheVariables": {
        "ENABLE_SANITIZERS": "ON",
        "SANITIZE_ADDRESS": "ON"
      }
    },
    {
      "name": "config-linux-gcc-dev",
      "inherits": [ "config-linux-gcc-debug" ],
      "displayName": "Linux GCC Debug with Sanitizers",
      "cacheVariables": {
        "ENABLE_SANITIZERS": "ON",
        "SANITIZE_ADDRESS": "ON"
      }
    },
    {
      "name": "config-linux-llvm-dev",
      "inherits": [ "config-linux-llvm-debug" ],
      "displayName": "Linux LLVM Debug with Sanitizers",
      "cacheVariables": {
        "ENABLE_SANITIZERS": "ON",
        "SANITIZE_ADDRESS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build-windows-msvc-dev",
      "configurePreset": "config-windows-msvc-dev",
      "displayName": "Windows MSVC Dev Build",
      "configuration": "Debug"
    },
    {
      "name": "build-windows-llvm-dev",
      "configurePreset": "config-windows-llvm-dev",
      "displayName": "Windows LLVM Dev Build",
      "configuration": "Debug"
    },
    {
      "name": "build-windows-gcc-dev",
      "configurePreset": "config-windows-gcc-dev",
      "displayName": "Windows GCC Dev Build",
      "configuration": "Debug"
    },
    {
      "name": "build-linux-gcc-dev",
      "configurePreset": "config-linux-gcc-dev",
      "displayName": "Linux GCC Dev Build",
      "configuration": "Debug"
    },
    {
      "name": "build-linux-llvm-dev",
      "configurePreset": "config-linux-llvm-dev",
      "displayName": "Linux LLVM Dev Build",
      "configuration": "Debug"
    }
  ],
  "testPresets": [
    {
      "name": "test-windows-msvc-dev",
      "configurePreset": "config-windows-msvc-dev",
      "displayName": "Windows MSVC Dev Tests",
      "output": { "outputOnFailure": true },
      "execution": {
        "noTestsAction": "error",
        "stopOnFailure": false
      }
    },
    {
      "name": "test-windows-llvm-dev",
      "configurePreset": "config-windows-llvm-dev",
      "displayName": "Windows LLVM Dev Tests",
      "output": { "outputOnFailure": true },
      "execution": {
        "noTestsAction": "error",
        "stopOnFailure": false
      }
    },
    {
      "name": "test-windows-gcc-dev",
      "configurePreset": "config-windows-gcc-dev",
      "displayName": "Windows GCC Dev Tests",
      "output": { "outputOnFailure": true },
      "execution": {
        "noTestsAction": "error",
        "stopOnFailure": false
      }
    },
    {
      "name": "test-linux-gcc-dev",
      "configurePreset": "config-linux-gcc-dev",
      "displayName": "Linux GCC Dev Tests",
      "output": { "outputOnFailure": true },
      "execution": {
        "noTestsAction": "error",
        "stopOnFailure": false
      }
    },
    {
      "name": "test-linux-llvm-dev",
      "configurePreset": "config-linux-llvm-dev",
      "displayName": "Linux LLVM Dev Tests",
      "output": { "outputOnFailure": true },
      "execution": {
        "noTestsAction": "error",
        "stopOnFailure": false
      }
    }
  ],
  "workflowPresets": [
    {
      "name": "dev-windows-msvc",
      "displayName": "Windows MSVC Development Workflow",
      "steps": [
        {
          "type": "configure",
          "name": "config-windows-msvc-dev"
        },
        {
          "type": "build",
          "name": "build-windows-msvc-dev"
        },
        {
          "type": "test",
          "name": "test-windows-msvc-dev"
        }
      ]
    },
    {
      "name": "dev-windows-llvm",
      "displayName": "Windows LLVM Development Workflow",
      "steps": [
        {
          "type": "configure",
          "name": "config-windows-llvm-dev"
        },
        {
          "type": "build",
          "name": "build-windows-llvm-dev"
        },
        {
          "type": "test",
          "name": "test-windows-llvm-dev"
        }
      ]
    },
    {
      "name": "dev-windows-gcc",
      "displayName": "Windows GCC Development Workflow",
      "steps": [
        {
          "type": "configure",
          "name": "config-windows-gcc-dev"
        },
        {
          "type": "build",
          "name": "build-windows-gcc-dev"
        },
        {
          "type": "test",
          "name": "test-windows-gcc-dev"
        }
      ]
    },
    {
      "name": "dev-linux-gcc",
      "displayName": "Linux GCC Development Workflow",
      "steps": [
        {
          "type": "configure",
          "name": "config-linux-gcc-dev"
        },
        {
          "type": "build",
          "name": "build-linux-gcc-dev"
        },
        {
          "type": "test",
          "name": "test-linux-gcc-dev"
        }
      ]
    },
    {
      "name": "dev-linux-llvm",
      "displayName": "Linux LLVM Development Workflow",
      "steps": [
        {
          "type": "configure",
          "name": "config-linux-llvm-dev"
        },
        {
          "type": "build",
          "name": "build-linux-llvm-dev"
        },
        {
          "type": "test",
          "name": "test-linux-llvm-dev"
        }
      ]
    }
  ]
}
